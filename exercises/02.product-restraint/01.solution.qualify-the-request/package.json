{
  "name": "exercises_02.product-restraint_01.solution.qualify-the-request",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./*"
  },
  "description": "A starter and reference for building full stack web applications",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/epicweb-dev/engineering-judgement.git"
  },
  "scripts": {
    "dev": "node ./cli.ts",
    "dev:client": "concurrently --kill-others-on-fail -n web,mcp-apps -c green,cyan \"npm run --silent dev:client:web\" \"npm run --silent dev:mcp-apps\"",
    "dev:client:web": "esbuild client/entry.tsx --bundle --format=esm --target=es2022 --outdir=public --entry-names=client-entry --chunk-names=assets/[name] --asset-names=assets/[name] --jsx=automatic --jsx-import-source=remix/component --watch",
    "dev:mcp-apps": "esbuild client/mcp-apps/schedule-widget.ts client/mcp-apps/schedule-host-widget.ts --bundle --format=esm --target=es2022 --outdir=public/mcp-apps --platform=browser --watch",
    "dev:worker": "node ./wrangler-env.ts dev --local",
    "deploy": "npm run build && node ./wrangler-env.ts deploy",
    "build:mcp-apps": "esbuild client/mcp-apps/schedule-widget.ts client/mcp-apps/schedule-host-widget.ts --bundle --format=esm --target=es2022 --outdir=public/mcp-apps --platform=browser",
    "build:client:web": "esbuild client/entry.tsx --bundle --format=esm --target=es2022 --outdir=public --entry-names=client-entry --chunk-names=assets/[name] --asset-names=assets/[name] --jsx=automatic --jsx-import-source=remix/component",
    "build:client": "npm run build:client:web && npm run build:mcp-apps",
    "build": "npm run build:client && node ./wrangler-env.ts build",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate:local": "node ./wrangler-env.ts d1 migrations apply APP_DB --local",
    "migrate:e2e": "node ./wrangler-env.ts d1 migrations apply APP_DB --local --persist-to .wrangler/state/e2e",
    "preview": "npm run build:mcp-apps && npm run migrate:local && node ./wrangler-env.ts dev --local",
    "preview:e2e": "npm run build:mcp-apps && npm run migrate:e2e && node ./wrangler-env.ts dev --local --persist-to .wrangler/state/e2e",
    "generate-types": "node ./wrangler-env.ts types ./types/worker-configuration.d.ts",
    "typecheck": "tsc -b --noEmit",
    "inspect": "npx -y @mcpjam/inspector inspector",
    "test:unit": "vitest run client server worker",
    "validate": "concurrently --kill-others-on-fail -n format,lint,build,typecheck,test,test:mcp -c green,yellow,blue,magenta,cyan,red \"npm run --silent format:check\" \"npm run --silent lint:fix\" \"npm run --silent build\" \"npm run --silent typecheck\" \"npm run --silent test:e2e\" \"npm run --silent test:mcp\"",
    "test:e2e": "node ./tools/prepare-e2e-env.ts && playwright test",
    "test:e2e:ui": "node ./tools/prepare-e2e-env.ts && playwright test --ui",
    "test:e2e:install": "playwright install chromium --with-deps",
    "test:mcp": "npm run build:mcp-apps && vitest run mcp/mcp-server-e2e.test.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@epic-web/config": "^1.24.1",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.70.0"
  },
  "prettier": "@epic-web/config/prettier",
  "dependencies": {
    "@epic-web/invariant": "^1.0.0",
    "@mcp-ui/server": "6.1.0",
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.7.4",
    "get-port": "^7.1.0",
    "remix": "3.0.0-alpha.3",
    "zod": "^4.3.6"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "Kent C. Dodds <me@kentcdodds.com> (https://kentcdodds.com/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kentcdodds/epic-scheduler/issues"
  },
  "homepage": "https://github.com/kentcdodds/epic-scheduler#readme"
}
